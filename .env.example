# Agora - Appels audio (requis pour activer les appels)
# Créez un compte sur https://console.agora.io
# 1. Créez un projet Agora
# 2. Copiez l'App ID (Public, utilisé côté client)
# 3. Activez le Primary Certificate et copiez-le (Privé, côté serveur uniquement)
NEXT_PUBLIC_AGORA_APP_ID=votre_agora_app_id
AGORA_APP_CERTIFICATE=votre_agora_app_certificate
