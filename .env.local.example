# Firebase Configuration
# Create a Firebase project at https://console.firebase.google.com
# Then copy your config values here

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key
NEXT_PUBLIC_FIRESTORE_FORCE_LONG_POLLING=false
NEXT_PUBLIC_SITE_URL=https://lakoumanman.com
NEXT_PUBLIC_URL=https://lakoumanman.com
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=your_api_key
RESEND_API_KEY=re_your_resend_api_key
CONTACT_FROM_EMAIL=Lakou Manman <noreply@lakoumanman.com>
CONTACT_TO_EMAIL=contact@lakoumanman.com
GROUP_NOTIFICATION_FROM_EMAIL=Lakou Manman <noreply@lakoumanman.com>
GROUP_NOTIFICATION_REPLY_TO_EMAIL=contact@lakoumanman.com

# Stripe Configuration
# Create a Stripe account at https://dashboard.stripe.com
# Then copy your keys here

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
MONCASH_CLIENT_ID=your_moncash_client_id
MONCASH_CLIENT_SECRET=your_moncash_client_secret
MONCASH_API_BASE_URL=https://sandbox.moncashbutton.digicelgroup.com/Api
MONCASH_GATEWAY_BASE_URL=https://sandbox.moncashbutton.digicelgroup.com/Moncash-middleware
MONCASH_WEBHOOK_SECRET=your_webhook_secret
MONCASH_WEBHOOK_REQUIRE_SIGNATURE=false
MONCASH_ALLOW_DEMO=false
