rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /posts/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /shop-items/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /messages/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /doctor_articles_pdfs/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(userId) && request.resource.contentType == 'application/pdf' && request.resource.size <= 20 * 1024 * 1024;
    }

    match /eventBookings/{userId}/{allPaths=**} {
      allow read: if signedIn() && (userId == request.auth.uid || request.auth.token.email.matches('(?i)^bannsoraya2@gmail\\.com$'));
      allow write: if signedIn()
        && userId == request.auth.uid
        && request.resource.size <= 15 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
